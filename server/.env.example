# Copy this file to .env and fill in all values before starting the server

# ── Required ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/gradzest
JWT_SECRET=<generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
PORT=5000

# ── Email (required for notifications, password reset, welcome emails) ─
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# ── Frontend URL (required in production for CORS + password reset links) ─
FRONTEND_URL=https://yourdomain.com

# ── Social OAuth (optional — leave blank to disable each provider) ────
GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
