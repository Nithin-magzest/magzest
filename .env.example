# Copy this file to .env and fill in values before starting or building the frontend

# ── Backend URL (leave empty for local dev — defaults to http://localhost:5000) ─
VITE_API_URL=https://your-backend.onrender.com

# ── Social OAuth (optional — leave blank to disable each provider) ────
VITE_GOOGLE_CLIENT_ID=
VITE_FACEBOOK_APP_ID=
